# Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Default Ollama model shown in UI (overridden by model selector)
OLLAMA_MODEL=llama3.2

# EIA API key — required for live EIA Weekly Petroleum Status Report data
# Free, instant registration: https://www.eia.gov/opendata/register.php
# Without this key the EIA section shows a prompt to add the key; all other
# data sources (CFTC COT, Baker Hughes, OPEC/IEA, yfinance) work without it.
EIA_API_KEY=
